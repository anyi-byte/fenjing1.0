  <div class="main-right">
    <div class="right-panel panel-message">
      <textarea name="task-message" class="scrollbar" id="task-message" spellcheck="false" readonly></textarea>
    </div>
    <div class="right-panel panel-chain">
      <textarea name="task-chain-message" class="scrollbar" id="task-chain-message" spellcheck="false" readonly></textarea>
    </div>
    <div class="right-panel panel-flash">
      <textarea name="task-flash-message" class="scrollbar" id="task-flash-message" spellcheck="false" readonly></textarea>
    </div>
    <div class="right-panel panel-interactive">
      <textarea name="interactive-message" class="scrollbar" id="interactive-message" spellcheck="false" readonly></textarea>
    </div>
    <div class="right-panel cmd-input">
      <form action="" onsubmit="onSubmitInteractiveTask(event)">
        <input type="text" id="form-chain-index" name="chain_index" value="1" placeholder="链路编号" />
        <input type="text" id="form-cmd" name="cmd" placeholder="cat /flag" />
        <input type="submit" value="执行" />
        <input type="hidden" name="type" value="interactive" />
        <input type="hidden" name="last_task_id" value="" />
      </form>
    </div>
  </div>
